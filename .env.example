# WyrmKeep dashboard — frontend environment variables.
# Copy to .env.local and adjust. Only VITE_-prefixed vars reach the browser.

# Base URL of the running WyrmKeep-API. Default when unset: http://localhost:8000
# VITE_API_BASE_URL=http://localhost:8000

# Mock mode toggle:
#   unset / "true"  -> in-memory mock backend (no Rust API needed) — default when no base URL
#   "false"         -> hit the live API at VITE_API_BASE_URL
# VITE_WYRMKEEP_USE_MOCK=false

# Clerk (identity gate). When set, users must sign up / sign in via Clerk before the
# "Connect API key" step. When UNSET, Clerk is bypassed (dev) and /sign-in offers a
# "Continue" link straight to /connect. Get pk_... from the Clerk dashboard.
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx
